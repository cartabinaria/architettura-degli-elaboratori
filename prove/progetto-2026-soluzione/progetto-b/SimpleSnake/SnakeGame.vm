function SnakeGame.new 0                       // costruttore SnakeGame.new; 0 variabili locali
  push constant 4                              // push 4 (numero campi dell’oggetto: snake, direction, pieceSize, nPieces)
  call Memory.alloc 1                          // alloca memoria per 4 campi; ritorna base address dell’oggetto
  pop pointer 0                                // THIS = base address dell’oggetto (this)

  push constant 15                             // push 15
  pop this 2                                   // this.pieceSize = 15

  push constant 10                             // push 10
  pop this 3                                   // this.nPieces = 10

  push constant 1                              // push 1
  pop this 1                                   // this.direction = 1

  push this 2                                  // push pieceSize
  push this 3                                  // push nPieces
  call Snake.new 2                             // chiama Snake.new(pieceSize, nPieces); ritorna riferimento Snake
  pop this 0                                   // this.snake = snake

  push pointer 0                               // push this (riferimento all’oggetto SnakeGame)
  return                                       // ritorna this


function SnakeGame.run 2                       // metodo run; 2 locali: key (local0), exit (local1)
  push argument 0                              // push this (arg0)
  pop pointer 0                                // THIS = arg0 (set contesto oggetto)

  push constant 0                              // push 0
  pop local 1                                  // exit = false (0)

  push constant 0                              // push 0
  pop local 0                                  // key = 0

  label WHILE_START0                           // while (!exit)  [inizio condizione]
    push local 1                               // push exit
    if-goto WHILE_END0                         // se condizione fine loop vera (exit), salta a WHILE_END0

    call Keyboard.keyPressed 0                 // key = Keyboard.keyPressed()
    pop local 0                                // salva il valore ritornato in local0 (key)

    push local 0                               // push key
    push constant 113                          // push 113 ('q')
    eq                                         // key == 113 ?
    push local 0                               // push key
    push constant 81                           // push 81 ('Q')
    eq                                         // key == 82 ?
    or                                         // (key==113) OR (key==81)
    if-goto IF_TRUE0                           // se vero, entra nel ramo exit=true
    goto IF_FALSE0                             // altrimenti salta il ramo

    label IF_TRUE0                             // if ((key==113) | (key==81)) { exit=true; }
      push constant 0                          // push 0
      not                                      // true (-1)
      pop local 1                              // exit = true
    label IF_FALSE0                            // fine if

    push local 0                               // push key
    push constant 132                          // push 132 (right arrow)
    eq                                         // key == 132 ?
    push this 1                                // push direction
    push constant 2                            // push 2 (left)
    eq                                         // direction == 2 ?
    not                                        // !(direction == 2)  (non permettere inversione)
    and                                        // (key==right) & (!(direction==2))
    if-goto IF_TRUE1                           // se vero, direction=1
    goto IF_FALSE1                             // altrimenti skip

    label IF_TRUE1                             // if right arrow and not going left
      push constant 1                          // push 1 (right)
      pop this 1                               // direction = 1
    label IF_FALSE1                            // fine if

    push local 0                               // push key
    push constant 130                          // push 130 (left arrow)
    eq                                         // key == 130 ?
    push this 1                                // push direction
    push constant 1                            // push 1 (right)
    eq                                         // direction == 1 ?
    not                                        // !(direction == 1)
    and                                        // (key==left) & (!(direction==1))
    if-goto IF_TRUE2                           // se vero, direction=2
    goto IF_FALSE2                             // altrimenti skip

    label IF_TRUE2                             // if left arrow and not going right
      push constant 2                          // push 2 (left)
      pop this 1                               // direction = 2
    label IF_FALSE2                            // fine if

    push local 0                               // push key
    push constant 131                          // push 131 (up arrow)
    eq                                         // key == 131 ?
    push this 1                                // push direction
    push constant 4                            // push 4 (down)
    eq                                         // direction == 4 ?
    not                                        // !(direction == 4)
    and                                        // (key==up) & (!(direction==4))
    if-goto IF_TRUE3                           // se vero, direction=3
    goto IF_FALSE3                             // altrimenti skip

    label IF_TRUE3                             // if up arrow and not going down
      push constant 3                          // push 3 (up)
      pop this 1                               // direction = 3
    label IF_FALSE3                            // fine if

    push local 0                               // push key
    push constant 133                          // push 133 (down arrow)
    eq                                         // key == 133 ?
    push this 1                                // push direction
    push constant 3                            // push 3 (up)
    eq                                         // direction == 3 ?
    not                                        // !(direction == 3)
    and                                        // (key==down) & (!(direction==3))
    if-goto IF_TRUE4                           // se vero, direction=4
    goto IF_FALSE4                             // altrimenti skip

    label IF_TRUE4                             // if down arrow and not going up
      push constant 4                          // push 4 (down)
      pop this 1                               // direction = 4
    label IF_FALSE4                            // fine if

    push this 0                                // push snake (this.snake)
    call Snake.erase 1                         // do snake.erase()
    pop temp 0                                 // scarta return dummy

    push this 0                                // push snake
    push this 1                                // push direction
    call Snake.move 2                          // chiama snake.move(direction); ritorna boolean
    not                                        // nega il risultato: !snake.move(direction)
    if-goto IF_TRUE5                           // se move ha fallito (negato true), exit=true
    goto IF_FALSE5                             // altrimenti continua

    label IF_TRUE5                             // if (!(snake.move(direction))) { exit=true; }
      push constant 0                          // push 0
      not                                      // true (-1)
      pop local 1                              // exit = true
    label IF_FALSE5                            // fine if

    push this 0                                // push snake
    call Snake.draw 1                          // do snake.draw()
    pop temp 0                                 // scarta dummy

    push constant 50                           // push 50 (ms / ticks)
    call Sys.wait 1                            // do Sys.wait(50)
    pop temp 0                                 // scarta dummy

    goto WHILE_START0                          // ripeti while
  label WHILE_END0                             // fine while

  push constant 0                              // push 0 (dummy return per void)
  return                                       // return
